# ════════════════════════════════════════════════════════════════
#  NUX Pulse — variáveis para produção (Supabase + Railway + Vercel)
# ════════════════════════════════════════════════════════════════
#
# Este arquivo é um MAPA das envs que precisam ser colocadas em cada host.
# NÃO é lido pelo app — cada host tem seu próprio dashboard de envs.

# ─── 1. RAILWAY (API) ───────────────────────────────────────────
# Cole estas no Railway → Project → Variables.

# Pegue em Supabase → Project Settings → Database → Connection string.
# São DUAS URLs:
#   DATABASE_URL  → Connection pooling (porta 6543, ?pgbouncer=true) — runtime
#   DIRECT_URL    → Direct connection  (porta 5432)                  — migrations
# Não esqueça de substituir [YOUR-PASSWORD] pela senha do DB.
DATABASE_URL="postgresql://postgres.PROJECT:SENHA@aws-X-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT:SENHA@aws-X-REGION.pooler.supabase.com:5432/postgres"

# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
API_SECRET_KEY="troque-por-um-valor-aleatorio-48-caracteres"

# Domínios que podem chamar a API (Vercel + localhost de dev).
# Depois de deploy do Vercel, substitua o valor de exemplo.
CORS_ORIGINS="https://nux-pulse.vercel.app,http://localhost:3010"

# Meta Marketing API
META_APP_ID=""
META_APP_SECRET=""
META_SYSTEM_USER_TOKEN=""

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_REFRESH_TOKEN=""
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""


# ─── 2. VERCEL (Web) ───────────────────────────────────────────
# Cole estas em Vercel → Project → Settings → Environment Variables.

# URL pública da API no Railway (pegar em Railway → Settings → Networking → Generate Domain)
NEXT_PUBLIC_API_URL="https://nux-pulse-api.up.railway.app"


# ─── 3. SUPABASE ────────────────────────────────────────────────
# Nenhuma env manual aqui — só criar o projeto e copiar a connection string
# pra DATABASE_URL do Railway acima.
